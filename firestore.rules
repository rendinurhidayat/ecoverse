rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- SHARED HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isGuru() {
      return isVerified() && (
        request.auth.token.email == 'studiopanlapan@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'guru')
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION RULES ---

    // 1. Users Collection
    match /users/{uid} {
      function isValidUser(data) {
        return data.uid == uid 
          && (data.email is string || !('email' in data))
          && (data.xp is number || !('xp' in data))
          && (data.level is number || !('level' in data))
          && (data.displayName is string || !('displayName' in data))
          && (data.completedQuizzes is number || !('completedQuizzes' in data))
          && (data.challengeProgress is map || !('challengeProgress' in data))
          && (data.school is string || !('school' in data))
          && (data.bio is string || !('bio' in data))
          && (data.streak is number || !('streak' in data))
          && (data.lastLogin is string || data.lastLogin is timestamp || !('lastLogin' in data))
          && (data.unlockedHabitats is list || !('unlockedHabitats' in data))
          && (data.badges is list || !('badges' in data))
          && (data.role is string || !('role' in data))
          && (data.createdAt is timestamp || !('createdAt' in data))
          && (data.updatedAt is timestamp || !('updatedAt' in data));
      }

      allow list: if isGuru();
      allow get: if isOwner(uid) || isGuru();
      allow create: if isOwner(uid) && isValidUser(incoming());
      allow update: if isOwner(uid) && isValidUser(incoming());
      allow delete: if isOwner(uid) || isGuru();
    }

    // 3. Quizzes
    match /quizzes/{quizId} {
      function isValidQuiz(data) {
        return data.question is string && data.question.size() <= 1000
          && data.options is list && data.options.size() >= 2
          && data.correctIndex is int && data.correctIndex >= 0 && data.correctIndex < data.options.size()
          && (data.category is string || !('category' in data))
          && (data.difficulty is string || !('difficulty' in data))
          && (data.createdBy is string || !('createdBy' in data));
      }

      allow read: if isVerified();
      allow create: if isGuru() && isValidQuiz(incoming());
      allow update: if isGuru() && isValidQuiz(incoming());
      allow delete: if isGuru();
    }

    // 4. Lab States
    match /labs/{stateId} {
      function isValidLabState(data) {
        return data.uid == request.auth.uid
          && data.labId is string
          && data.data is map;
      }

      allow list: if isVerified() && (resource.data.uid == request.auth.uid || isGuru());
      allow get: if isValidId(stateId) && isVerified() && (resource.data.uid == request.auth.uid || isGuru());
      allow create: if isValidId(stateId) && isVerified() && isValidLabState(incoming());
      allow update: if isValidId(stateId) && isVerified() && resource.data.uid == request.auth.uid && isValidLabState(incoming());
      allow delete: if isValidId(stateId) && isVerified() && (resource.data.uid == request.auth.uid || isGuru());
    }

    // 5. Learning Materials
    match /materials/{materialId} {
      function isValidMaterial(data) {
        return data.category is string 
          && data.grade is string
          && data.chapter is string
          && data.question is string && data.question.size() <= 500
          && data.answer is string && data.answer.size() <= 2000
          && (data.createdBy is string || !('createdBy' in data))
          && (data.createdAt is timestamp || !('createdAt' in data))
          && (data.updatedAt is timestamp || !('updatedAt' in data));
      }

      allow read: if isVerified();
      allow create: if isVerified() && isValidMaterial(incoming());
      allow update: if isVerified() 
        && (isGuru() || existing().createdBy == request.auth.uid || !existing().keys().has('createdBy')) 
        && isValidMaterial(incoming());
      allow delete: if isVerified() 
        && (isGuru() || existing().createdBy == request.auth.uid || !existing().keys().has('createdBy'));
    }

    // 6. Story Progress
    match /storyProgress/{progressId} {
      function isValidStoryProgress(data) {
        return data.uid == request.auth.uid
          && data.currentSceneId is int
          && data.phase is string
          && data.state is map
          && (data.selectedChoiceIndex is int || data.selectedChoiceIndex == null || !data.keys().has('selectedChoiceIndex'));
      }

      allow list: if isVerified() && (resource.data.uid == request.auth.uid || isGuru()); 
      allow get: if isValidId(progressId) && isVerified() && (resource.data.uid == request.auth.uid || isGuru());
      allow create: if isValidId(progressId) && isVerified() && isValidStoryProgress(incoming());
      allow update: if isValidId(progressId) && isVerified() && resource.data.uid == request.auth.uid && isValidStoryProgress(incoming());
      allow delete: if isValidId(progressId) && isVerified() && (resource.data.uid == request.auth.uid || isGuru());
    }

    // 7. Quiz Results (Leaderboard)
    match /quizResults/{resultId} {
      function isValidQuizResult(data) {
        return data.uid == request.auth.uid
          && data.displayName is string && data.displayName.size() <= 100
          && data.score is number
          && data.totalQuestions is number
          && data.xpEarned is number
          && data.date is string && data.date.size() == 10
          && (data.createdAt == request.time || data.createdAt == null);
      }

      allow list: if isVerified() && (resource.data.date != null || isGuru());
      allow get: if isVerified();
      allow create: if isVerified() && isValidQuizResult(incoming());
      allow delete: if isVerified() && (resource.data.uid == request.auth.uid || isGuru());
    }
  }
}
